# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/neondb?sslmode=require"

# NextAuth
AUTH_SECRET="generate with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Gmail — Magic Link Auth (sign-in emails)
GMAIL_USER="your-auth-account@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Gmail — Fee Reminders (can be a different account/address)
# Leave blank to disable reminders until ready
REMINDER_EMAIL_FROM="LE Fees <fees@letsent.com>"
REMINDER_GMAIL_USER="fees@gmail.com"
REMINDER_GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
# Optional: shown in reminder emails as payment instructions
REMINDER_PAYMENT_INSTRUCTIONS=""

# External API key secret
API_KEY_SECRET="generate with: openssl rand -hex 32"

# Cron job secret (protect /api/cron/* endpoints)
CRON_SECRET="generate with: openssl rand -hex 32"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
