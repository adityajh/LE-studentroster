generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  lockedSchedules   FeeSchedule[]     @relation("LockedBy")
  apiKeys           ApiKey[]
  uploadedDocuments StudentDocument[] @relation("UploadedDocuments")
  auditLogs         StudentAuditLog[] @relation("AuditLogs")
  recordedPayments  Payment[]         @relation("RecordedPayments")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
}

enum StudentStatus {
  OFFERED
  ACTIVE
  ALUMNI
  WITHDRAWN
}

enum InstallmentType {
  ONE_TIME
  ANNUAL
  CUSTOM
}

enum InstallmentStatus {
  UPCOMING
  DUE
  OVERDUE
  PARTIAL
  PAID
}

enum OfferType {
  FIRST_N_REGISTRATIONS
  EARLY_BIRD
  ACCEPTANCE_7DAY
  FULL_PAYMENT
  REFERRAL
}

enum ScholarshipCategory {
  A
  B
}

enum ReminderType {
  ONE_MONTH
  ONE_WEEK
  DUE_DATE
}

enum DocumentType {
  STUDENT_PHOTO
  TENTH_MARKSHEET
  TWELFTH_MARKSHEET
  ACCEPTANCE_LETTER
  AADHAR_CARD
  DRIVERS_LICENSE
}

enum EmailStatus {
  SENT
  FAILED
  BOUNCED
}

enum PaymentMode {
  CASH
  CHEQUE
  NEFT
  UPI
  RTGS
  OTHER
}

// ─── Batch & Programs ────────────────────────────────────────────────────────

model Batch {
  id        String   @id @default(cuid())
  year      Int      @unique
  name      String
  createdAt DateTime @default(now())

  programs    Program[]
  feeSchedule FeeSchedule?
  students    Student[]
}

model Program {
  id              String   @id @default(cuid())
  batchId         String
  name            String
  totalFee        Decimal  @db.Decimal(12, 2)
  registrationFee Decimal  @db.Decimal(12, 2)
  year1Fee        Decimal  @db.Decimal(12, 2)
  year2Fee        Decimal  @db.Decimal(12, 2)
  year3Fee        Decimal  @db.Decimal(12, 2)
  targetStudents  Int?
  description     String?  @db.Text
  yearWiseDetails Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  batch    Batch     @relation(fields: [batchId], references: [id])
  students Student[]
}

// ─── Fee Schedule ────────────────────────────────────────────────────────────

model FeeSchedule {
  id         String    @id @default(cuid())
  batchId    String    @unique
  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  batch        Batch         @relation(fields: [batchId], references: [id])
  lockedBy     User?         @relation("LockedBy", fields: [lockedById], references: [id])
  offers       Offer[]
  scholarships Scholarship[]
}

model Offer {
  id            String    @id @default(cuid())
  feeScheduleId String
  name          String
  type          OfferType
  waiverAmount  Decimal   @db.Decimal(12, 2)
  deadline      DateTime?
  conditions    Json?
  createdAt     DateTime  @default(now())

  feeSchedule   FeeSchedule    @relation(fields: [feeScheduleId], references: [id])
  studentOffers StudentOffer[]
}

model Scholarship {
  id            String              @id @default(cuid())
  feeScheduleId String
  category      ScholarshipCategory
  name          String
  minAmount     Decimal             @db.Decimal(12, 2)
  maxAmount     Decimal             @db.Decimal(12, 2)
  createdAt     DateTime            @default(now())

  feeSchedule         FeeSchedule          @relation(fields: [feeScheduleId], references: [id])
  studentScholarships StudentScholarship[]
}

// ─── Master Student Roster ───────────────────────────────────────────────────

model Student {
  id             String        @id @default(cuid())
  rollNo         String?       @unique  // null until enrolment confirmed (status=OFFERED)
  name           String
  firstName      String?
  lastName       String?
  contact        String?
  email          String?
  bloodGroup     String?
  city           String?
  address        String?       @db.Text
  localAddress   String?       @db.Text
  parent1Name    String?
  parent1Email   String?
  parent1Phone   String?
  parent2Name    String?
  parent2Email   String?
  parent2Phone   String?
  localGuardianName  String?
  localGuardianPhone String?
  localGuardianEmail String?
  batchId        String
  programId      String
  enrollmentDate DateTime      @default(now())
  status         StudentStatus @default(OFFERED)

  // Offer-window tracking
  offerSentAt           DateTime?
  offerExpiresAt        DateTime?
  offerReminder1SentAt  DateTime?
  offerReminder2SentAt  DateTime?
  offerRevised          Boolean   @default(false)
  onboardingEmailSentAt DateTime?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  batch   Batch   @relation(fields: [batchId], references: [id])
  program Program @relation(fields: [programId], references: [id])

  financial    StudentFinancial?
  offers       StudentOffer[]
  scholarships StudentScholarship[]
  deductions   StudentDeduction[]
  installments Installment[]
  payments     Payment[]
  documents    StudentDocument[]
  auditLogs    StudentAuditLog[]
}

model StudentDocument {
  id           String       @id @default(cuid())
  studentId    String
  type         DocumentType
  fileName     String
  fileUrl      String       @db.Text
  fileSize     Int?
  uploadedAt   DateTime     @default(now())
  uploadedById String?

  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("UploadedDocuments", fields: [uploadedById], references: [id])
}

// ─── Student Financials ──────────────────────────────────────────────────────

model StudentFinancial {
  id                   String          @id @default(cuid())
  studentId            String          @unique
  baseFee              Decimal         @db.Decimal(12, 2)
  totalWaiver          Decimal         @db.Decimal(12, 2) @default(0)
  totalDeduction       Decimal         @db.Decimal(12, 2) @default(0)
  netFee               Decimal         @db.Decimal(12, 2)
  registrationPaid     Boolean         @default(false)
  registrationPaidDate DateTime?
  depositPaid          Boolean         @default(false)
  depositAmount        Decimal?        @db.Decimal(12, 2)
  depositPaidDate      DateTime?
  installmentType      InstallmentType
  isLocked             Boolean         @default(false)
  lockedAt             DateTime?
  customTerms          String?         @db.Text
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentOffer {
  id           String   @id @default(cuid())
  studentId    String
  offerId      String
  waiverAmount Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  offer   Offer   @relation(fields: [offerId], references: [id])

  @@unique([studentId, offerId])
}

model StudentScholarship {
  id            String   @id @default(cuid())
  studentId     String
  scholarshipId String
  amount        Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scholarship Scholarship @relation(fields: [scholarshipId], references: [id])

  @@unique([studentId, scholarshipId])
}

model StudentDeduction {
  id          String   @id @default(cuid())
  studentId   String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ─── Installments ────────────────────────────────────────────────────────────

model Installment {
  id            String            @id @default(cuid())
  studentId     String
  year          Int
  label         String
  dueDate       DateTime
  amount        Decimal           @db.Decimal(12, 2)
  status        InstallmentStatus @default(UPCOMING)
  paidDate      DateTime?
  paidAmount    Decimal?          @db.Decimal(12, 2)
  paymentMethod String?
  referenceNo   String?           // For legacy tracking
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments     Payment[]
  reminderLogs ReminderLog[]
}

model ReminderLog {
  id            String       @id @default(cuid())
  installmentId String
  type          ReminderType
  sentAt        DateTime     @default(now())
  readAt        DateTime?
  emailStatus   EmailStatus
  errorMessage  String?      @db.Text
  createdAt     DateTime     @default(now())

  installment Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)
}

model ReminderSetting {
  id        String   @id @default(cuid())
  type      String   @unique // "ONE_MONTH", "ONE_WEEK", "DUE_DATE"
  daysOut   Int
  subject   String
  bodyText  String   @db.Text @default("")
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── API Keys ────────────────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  createdById String
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  createdBy User @relation(fields: [createdById], references: [id])
}

model Payment {
  id             String       @id @default(cuid())
  studentId      String
  installmentId  String?
  date           DateTime
  amount         Decimal      @db.Decimal(12, 2)
  payerName      String?
  paymentMode    PaymentMode?
  referenceNo    String?      @db.Text
  notes          String?      @db.Text
  recordedById   String?
  receiptSentAt  DateTime?
  createdAt      DateTime     @default(now())

  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  installment Installment? @relation(fields: [installmentId], references: [id])
  recordedBy  User?        @relation("RecordedPayments", fields: [recordedById], references: [id])
}

// ─── System Settings ─────────────────────────────────────────────────────────

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model StudentAuditLog {
  id          String   @id @default(cuid())
  studentId   String
  changedBy   String
  field       String
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  reason      String?  @db.Text
  createdAt   DateTime @default(now())

  student       Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  changedByUser User    @relation("AuditLogs", fields: [changedBy], references: [id])
}

